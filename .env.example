# ── LLM & Embeddings ────────────────────────────────────────────────────────
GOOGLE_API_KEY=                    # Gemini API + Google Text Embedding API
                                   # Get at: https://aistudio.google.com/app/apikey

# ── Document Parsing ─────────────────────────────────────────────────────────
LLAMA_CLOUD_API_KEY=               # LlamaParse API key
                                   # Get at: https://cloud.llamaindex.ai

# ── Vector Database (Qdrant) ─────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333   # Local dev; replace with Qdrant Cloud URL in prod
QDRANT_API_KEY=                    # Leave empty for local dev; required for Qdrant Cloud

# ── Recruitment Batch ────────────────────────────────────────────────────────
BATCH_ID=GDGOC_Hackathon_2026      # Identifies the current recruitment round

# ── OSINT ────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=
PROXYCURL_API_KEY=
GITHUB_PAT=                        # Optional: raises GitHub API rate limit (60 → 5000 req/hr)

# ── Email ────────────────────────────────────────────────────────────────────
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=                      # PostgreSQL: postgresql://user:pass@host:5432/dbname

# ── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON=     # Path to service account JSON file or inline JSON
